# Copy to keystore.properties at the repo root for local signed release builds.
# This file is gitignored — never commit keystore.properties or *.jks files.
#
# GitHub Actions uses repository secrets instead (see .github/workflows/android-release.yml):
#   ANDROID_KEYSTORE_BASE64  — base64-encoded release.jks
#   ANDROID_KEYSTORE_PASSWORD
#   ANDROID_KEY_ALIAS          (key0)
#   ANDROID_KEY_PASSWORD
#
# Encode your keystore for GitHub (source: ~/Documents/keystore.jks copied to composeApp/keystore/release.jks):
#   base64 -w0 composeApp/keystore/release.jks
#
# Or upload all signing secrets at once (after `gh auth login`):
#   ./scripts/setup-github-secrets.sh
storeFile=composeApp/keystore/release.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=key0
keyPassword=YOUR_KEY_PASSWORD
